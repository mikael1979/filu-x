{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/modes/single.json",
  
  "type": "object",
  
  "properties": {
    "mode": {
      "const": "single"
    },
    
    "privacy_policy": {
      "const": "public-only",
      "description": "Single-file mode only supports public posts"
    },
    
    "notice": {
      "type": "string",
      "description": "Optional notice about public-only nature"
    },
    
    "posts": {
      "type": "array",
      "items": {
        "$ref": "../posts/post.json"
      },
      "description": "All posts in a single array"
    }
  },
  
  "required": ["privacy_policy"],
  
  "allOf": [
    {
      "if": {
        "properties": {
          "posts": { "type": "array" }
        }
      },
      "then": {
        "properties": {
          "posts": {
            "items": {
              "not": {
                "required": ["encrypted"]
              }
            }
          }
        }
      }
    }
  ]
}
