{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/core/document.json",
  
  "required": ["version", "mode", "created", "profile"],
  
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d{3}\\.\\d{3}\\.\\d{3}$",
      "description": "Filu-X specification version (e.g., 001.000.000)",
      "examples": ["001.000.000"]
    },
    
    "mode": {
      "type": "string",
      "enum": ["single", "linked", "hybrid"],
      "description": "Storage mode"
    },
    
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 creation timestamp"
    },
    
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 last update timestamp"
    },
    
    "profile": {
      "$ref": "profile.json"
    },
    
    "protocols": {
      "$ref": "protocols.json"
    },
    
    "signature": {
      "$ref": "signature.json"
    },
    
    "statistics": {
      "type": "object",
      "properties": {
        "total_posts": {
          "type": "integer",
          "minimum": 0
        },
        "total_media": {
          "type": "integer",
          "minimum": 0
        },
        "last_sequence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9999999
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    }
  }
}
