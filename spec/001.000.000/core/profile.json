{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/core/profile.json",
  
  "type": "object",
  "required": ["name", "pubkey"],
  
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Display name"
    },
    
    "pubkey": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Author's public key (hex, 64 chars)"
    },
    
    "avatar": {
      "type": "string",
      "format": "uri",
      "description": "Avatar image URI"
    },
    
    "bio": {
      "type": "string",
      "maxLength": 500,
      "description": "Short biography"
    },
    
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Personal website"
    },
    
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Profile creation time"
    },
    
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "Profile last update"
    }
  },
  
  "additionalProperties": true
}
