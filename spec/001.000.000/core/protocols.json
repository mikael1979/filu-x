{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/core/protocols.json",
  
  "type": "object",
  
  "properties": {
    "priority": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ipfs", "https", "nostr", "tor", "dat", "arweave"]
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Protocol priority order"
    }
  },
  
  "patternProperties": {
    "^[a-z0-9-]+$": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Primary URL for this protocol"
        },
        "mirrors": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "description": "Mirror URLs"
        },
        "sync": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["public", "private", "media", "archive", "text-only"]
          },
          "description": "What content is synced to this protocol"
        }
      },
      "additionalProperties": true
    }
  },
  
  "minProperties": 1,
  "additionalProperties": true
}
