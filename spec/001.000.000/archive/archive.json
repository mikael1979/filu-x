{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/archive/archive.json",
  
  "type": "object",
  
  "properties": {
    "urls": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "minProperties": 1,
      "description": "Protocol-specific archive locations"
    },
    
    "range": {
      "type": "object",
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^\\d{7}\\.[a-f0-9]{12}$",
          "description": "First post ID in archive"
        },
        "end": {
          "type": "string",
          "pattern": "^\\d{7}\\.[a-f0-9]{12}$",
          "description": "Last post ID in archive"
        },
        "start_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "First sequence number"
        },
        "end_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Last sequence number"
        }
      },
      "required": ["start", "end"]
    },
    
    "timerange": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string",
          "format": "date-time"
        },
        "to": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["from", "to"]
    },
    
    "post_count": {
      "type": "integer",
      "minimum": 1
    },
    
    "filux_version": {
      "type": "string",
      "pattern": "^\\d{3}\\.\\d{3}\\.\\d{3}$"
    },
    
    "includes_private": {
      "type": "boolean",
      "default": false,
      "description": "Whether archive contains private posts"
    },
    
    "format": {
      "type": "string",
      "enum": ["single-file", "linked", "compressed"],
      "default": "single-file"
    }
  },
  
  "required": ["urls", "range", "post_count"]
}
