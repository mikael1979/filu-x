{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/posts/media.json",
  
  "type": "object",
  "required": ["type", "urls"],
  
  "properties": {
    "type": {
      "type": "string",
      "enum": ["image", "video", "audio", "document", "link", "embed"],
      "description": "Media type"
    },
    
    "urls": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "minProperties": 1,
      "description": "Protocol-specific URLs"
    },
    
    "alt": {
      "type": "string",
      "maxLength": 500,
      "description": "Alternative text"
    },
    
    "caption": {
      "type": "string",
      "maxLength": 1000,
      "description": "Media caption"
    },
    
    "width": {
      "type": "integer",
      "minimum": 1,
      "description": "Width in pixels"
    },
    
    "height": {
      "type": "integer",
      "minimum": 1,
      "description": "Height in pixels"
    },
    
    "duration": {
      "type": "integer",
      "minimum": 1,
      "description": "Duration in seconds"
    },
    
    "poster": {
      "type": "string",
      "format": "uri",
      "description": "Thumbnail/preview image"
    },
    
    "size": {
      "type": "integer",
      "minimum": 1,
      "description": "File size in bytes"
    }
  },
  
  "additionalProperties": true
}
