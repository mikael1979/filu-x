{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/posts/post_ref.json",
  
  "type": "object",
  "required": ["id", "urls"],
  
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^\\d{7}\\.[a-f0-9]{12}$"
    },
    
    "urls": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "minProperties": 1,
      "description": "Protocol-specific URLs to the post file"
    },
    
    "summary": {
      "type": "string",
      "maxLength": 200,
      "description": "Short summary/preview"
    },
    
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Original post creation time"
    }
  },
  
  "oneOf": [
    { "$ref": "../privacy/public.json" },
    { "$ref": "../privacy/private.json" }
  ]
}
