{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "file:///spec/001.000.000/privacy/public.json",
  
  "type": "object",
  
  "properties": {
    "public_key": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Public key for this post (included with reference)"
    },
    
    "privacy": {
      "type": "object",
      "properties": {
        "visibility": {
          "const": "public"
        }
      },
      "required": ["visibility"]
    }
  },
  
  "required": ["public_key"]
}
